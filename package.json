{
  "name": "shared-fate-server",
  "version": "1.0.0",
  "private": true,
  "description": "Dedicated WebSocket server for Shared Fate",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "docker:build": "docker build -t shared-fate-server .",
    "docker:run": "docker run --rm -p 8080:8080 --name shared-fate-server shared-fate-server"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "express": "^4.21.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
